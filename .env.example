# MLflow tracking server URI (default: local ./mlruns folder)
# MLFLOW_TRACKING_URI=http://localhost:5000

# Directory where audit JSONL files are stored (default: ./audit_logs/)
# AUDIT_LOG_DIR=./audit_logs

# Secret key used to sign audit records with HMAC-SHA256
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# AUDIT_HMAC_SECRET=your-secret-key-here
